# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Server-only (Settings → API → service_role). Never expose in client code or commit .env.local.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Your fixed user id for all workout data (any UUID v4). Same value must stay stable so history matches.
# Example: a1000000-0000-4000-8000-000000000001
KAI_PLAN_USER_ID=

# Oura Cloud API (OAuth2). In the Oura app, register the same redirect URIs (local + prod).
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
# Local dev (must be http://localhost, not 127.0.0.1 — Oura requires that for http).
OURA_REDIRECT_URI=http://localhost:3000/api/oura/callback
